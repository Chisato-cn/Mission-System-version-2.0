.default #PropertyContainer {
    flex-direction: row;
    padding: 5px;
    margin-bottom: 5px;
    background-color: rgba(71, 71, 71, 0.8);
    justify-content: space-between;
    flex-shrink: 0;
}

.default #PropertyContainer #PropertyName {
    -unity-text-align: middle-center;
    margin: 0;
    padding: 0;
    flex-shrink: 0;
    text-overflow: ellipsis;
    white-space: nowrap;
    overflow: hidden;
}

.seventy-percent-width-property-field {
    width: 90%;
    flex-shrink: 1;
}

.auto-width-property-field {
    width: auto;
    flex-shrink: 0;
}

.internal {
    
}

.internal .unity-label {
    -unity-text-align: middle-center;
    margin: 0;
    padding: 0;
    flex-shrink: 0;
    text-overflow: ellipsis;
    white-space: nowrap;
    overflow: hidden;
}

.internal .unity-property-field {
    width: 90%;
    flex-shrink: 1;
}

.internal #PropertyContainer {
    flex-direction: row;
    padding: 5px;
    margin-bottom: 5px;
    background-color: rgba(88, 88, 88, 0.8);
    justify-content: space-between;
    flex-shrink: 0;
    flex-grow: 1;
}